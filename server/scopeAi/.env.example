# Copy this file to .env and replace all placeholder values.
GEMINI_API_KEY=replace_with_a_new_google_ai_studio_key
DJANGO_SECRET_KEY=replace_with_a_long_random_django_secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=api.example.com,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://your-project.vercel.app
CSRF_TRUSTED_ORIGINS=https://api.example.com

# Enable these after an HTTPS reverse proxy is configured for the API domain.
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SECURE_COOKIES=False
DJANGO_HSTS_SECONDS=0
DJANGO_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_HSTS_PRELOAD=False

USER_AGENT=ScopeAI/1.0 (contact: you@example.com)
